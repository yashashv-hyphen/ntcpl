# ── AI provider credentials ───────────────────────────────────────────────────
# At least one of these groups must be set depending on your chosen provider.

# Google Gemini (recommended for image analysis + copy generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (used by the "demo" provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# HuggingFace (image generation + optional vision analysis)
HF_TOKEN=your_huggingface_token_here

# Cloudflare Workers AI (image generation + text generation)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# ── Ollama local LLM (recommended — free, private, no quotas) ─────────────────
# Run `ollama serve` to start the server, then pull the models below:
#   ollama pull llama3.2-vision:11b   # ~8 GB — vision/image analysis
#   ollama pull qwen2.5:14b           # ~8.7 GB — listing copy generation
# Both models fit in 16 GB RAM (Ollama auto-swaps between them).
OLLAMA_HOST=http://localhost:11434
# OLLAMA_VISION_MODEL=llama3.2-vision:11b
# OLLAMA_TEXT_MODEL=qwen2.5:14b
# OLLAMA_TIMEOUT=180

# ── Provider selection ────────────────────────────────────────────────────────
# Options: ollama | cloudflare | gemini | hf | demo | bedrock
# Set to "auto" (or omit) to use Ollama first, then cloud APIs as fallback.
AI_PROVIDER=auto


# ── Optional tuning ───────────────────────────────────────────────────────────
# HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# HF_MAX_RETRIES=4
# HF_RETRY_BASE_SECONDS=10
# CATALOG_SKU_WORKERS=4
# MIN_IMAGE_DIMENSION=500
# FAL_IMAGE_MODEL=fal-ai/flux/dev   # higher quality / fewer distorted scenes than flux/schnell (slower, costs more per image)
